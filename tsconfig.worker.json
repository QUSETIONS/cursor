{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist-worker",
    "rootDir": "./",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "worker/**/*",
    "electron/**/*"
  ],
  "exclude": [
    "node_modules",
    "src",
    "dist"
  ]
}
