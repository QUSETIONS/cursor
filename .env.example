# ─── Nirvana Registration Engine — Environment Variables ───

# Catch-All Domain for email routing
CATCH_ALL_DOMAIN=nirvana-farm-2026.cyou

# IMAP Credentials (Gmail App Password recommended)
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-gmail-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Sub2API Gateway (optional)
SUB2API_API_KEY=

# Watchdog Webhook (optional)
WATCHDOG_WEBHOOK_URL=
